// Sprint 20.0 — template do Secrets.xcconfig (este example é commitado;
// o Secrets.xcconfig real é GITIGNORADO).
//
// Setup (1x por máquina):
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//   → preencher a ANON key (mesma credencial PÚBLICA que o site usa;
//     NUNCA colocar service role aqui) e rodar `xcodegen generate`.
//
// GOTCHA: em xcconfig "//" inicia comentário. Numa URL, use $() pra
// quebrar a sequência, como abaixo.

SUPABASE_URL = https:/$()/qajjpjmybmqqwflytcpr.supabase.co
SUPABASE_ANON_KEY = COLE_A_ANON_KEY_AQUI

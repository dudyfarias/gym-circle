{
  "name": "gym-circle",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "generate:apple-secret": "node generate-apple-secret.js",
    "build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "test": "vitest run",
    "test:streak": "vitest run packages/core/src/domain/streak.test.ts",
    "cap:add:ios": "cap add ios && npm run cap:patch:ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync && npm run cap:patch:ios",
    "cap:sync:ios": "cap sync ios && npm run cap:patch:ios",
    "cap:build:ios": "npm run build && npm run cap:sync:ios",
    "cap:patch:ios": "node scripts/patch-ios-permissions.mjs",
    "cap:doctor": "cap doctor",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.6"
  }
}

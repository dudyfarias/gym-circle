{
  "name": "gym-circle",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "test": "vitest run",
    "test:streak": "vitest run packages/core/src/domain/streak.test.ts",
    "cap:add:ios": "cap add ios && npm run cap:patch:ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync && npm run cap:patch:ios",
    "cap:patch:ios": "node scripts/patch-ios-permissions.mjs",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  }
}
